# terraform.tfvars.example
# Copy this file to terraform.tfvars and fill in your values.

aws_region         = "ap-southeast-1"          # AWS region for deployment
environment        = "prod"                    # Target environment (prod)
cluster_name       = "gitops-cluster-prod"     # Name of the EKS cluster
subnet_ids         = ["subnet-xxx", "subnet-yyy", "subnet-zzz"]  # VPC subnet IDs
node_instance_type = "t3.large"                # EC2 instance type for worker nodes
desired_size       = 3                         # Desired number of worker nodes
min_size           = 3                         # Minimum worker nodes
max_size           = 10                        # Maximum worker nodes
